    "bootstrap": "pnpm build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "cpy-cli": "^7.0.0",
    "esbuild": "^0.27.3",
    "esbuild-jest": "^0.5.0",
    "jest": "^30.2.0"
  },
  "peerDependencies": {
    "typescript": ">=4.4.4"
  }
}
